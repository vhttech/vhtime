#!/bin/sh
set -e

cd "$(dirname "$0")/.."

VERSION=$(grep '^version=' Makefile | cut -d= -f2 | tr -d ' ')
PKG_NAME="ibus-vhtime"
DIST_DIR="dist"
STAGING="$DIST_DIR/.staging"

case "$(uname -m)" in
    x86_64)  DEB_ARCH="amd64";  RPM_ARCH="x86_64"  ;;
    aarch64) DEB_ARCH="arm64";  RPM_ARCH="aarch64" ;;
    armv7l)  DEB_ARCH="armhf";  RPM_ARCH="armv7hl" ;;
    i686)    DEB_ARCH="i386";   RPM_ARCH="i686"    ;;
    *)       DEB_ARCH="$(uname -m)"; RPM_ARCH="$(uname -m)" ;;
esac

echo "==> ibus-vhtime ${VERSION} (${DEB_ARCH})"

# Build binary
echo "==> Building binary"
sh scripts/build

# Prepare staging
rm -rf "$STAGING"
mkdir -p "$DIST_DIR"
sh scripts/install /usr "$STAGING"

# Binary tarball
TAR_OUT="${PKG_NAME}-${VERSION}-linux-${DEB_ARCH}.tar.gz"
echo "==> ${TAR_OUT}"
tar -czf "$DIST_DIR/$TAR_OUT" -C "$STAGING" usr

# DEB
if command -v dpkg-deb >/dev/null 2>&1; then
    DEB_OUT="${PKG_NAME}_${VERSION}_${DEB_ARCH}.deb"
    echo "==> ${DEB_OUT}"
    mkdir -p "$STAGING/DEBIAN"
    cat > "$STAGING/DEBIAN/control" <<EOF
Package: $PKG_NAME
Version: $VERSION
Architecture: $DEB_ARCH
Maintainer: Fx Phúc Vinh <vinhhp@vhttech.com>
Depends: ibus, libgtk-3-0
Homepage: https://github.com/vhtech/ibus-vhtime
Description: A Vietnamese IME for IBus
 Vietnamese input method editor supporting Telex, VNI, VIQR and more.
EOF
    cd "$STAGING" && find usr -type f | sort | xargs md5sum > DEBIAN/md5sums && cd - >/dev/null
    if command -v fakeroot >/dev/null 2>&1; then
        fakeroot dpkg-deb --build "$STAGING" "$DIST_DIR/$DEB_OUT"
    else
        dpkg-deb --root-owner-group --build "$STAGING" "$DIST_DIR/$DEB_OUT"
    fi
else
    echo "    [skip .deb] dpkg-deb not found"
fi

# RPM
if command -v rpmbuild >/dev/null 2>&1; then
    RPM_OUT="${PKG_NAME}-${VERSION}-1.${RPM_ARCH}.rpm"
    echo "==> ${RPM_OUT}"
    mkdir -p ~/rpmbuild/{SOURCES,SPECS,BUILD,RPMS,SRPMS}
    tar -czf ~/rpmbuild/SOURCES/${PKG_NAME}-${VERSION}.tar.gz \
        --transform "s/^\./${PKG_NAME}-${VERSION}/" \
        --exclude=.git --exclude="*.tar.gz" --exclude=dist .
    sed "s/^Version:.*/Version: ${VERSION}/" build/rpm/ibus-vhtime.spec \
        > ~/rpmbuild/SPECS/ibus-vhtime.spec
    rpmbuild -bb --quiet ~/rpmbuild/SPECS/ibus-vhtime.spec
    find ~/rpmbuild/RPMS -name "${PKG_NAME}-${VERSION}*.rpm" \
        -exec cp {} "$DIST_DIR/" \;
else
    echo "    [skip .rpm] rpmbuild not found"
fi

rm -rf "$STAGING"

echo ""
echo "dist/:"
ls -lh "$DIST_DIR/"
