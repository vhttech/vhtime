<component>
    <name>org.freedesktop.IBus.vhtime</name>
    <description>Vietnamese input engine for IBus</description>
    <exec>/usr/local/lib/ibus-vhtime/ibus-engine-vhtime --ibus</exec>
    <version>1.0.1</version>
    <author>Luong Thanh Lam &lt;ltlam93@gmail.com&gt;</author>
    <license>GPLv3</license>
    <homepage>https://github.com/vhtech/ibus-vhtime/</homepage>
    <textdomain>ibus-vhtime</textdomain>
    <engines>
          <engine>
              <symbol>vi</symbol>
              <name>Vhtime</name>
              <language>vi</language>
              <license>GPLv3</license>
              <author>Luong Thanh Lam &lt;ltlam93@gmail.com&gt;</author>
	      <icon>/usr/local/share/ibus-vhtime/icons/vi.svg</icon>
              <layout>default</layout>
              <longname>Vhtime</longname>
              <description>Vietnamese input method editor</description>
	      <setup>/usr/local/lib/ibus-vhtime/ibus-engine-vhtime -gui</setup>
              <rank>1</rank>
          </engine>
          <engine>
              <symbol>vi</symbol>
              <name>Vhtime::Us</name>
              <language>vi</language>
              <license>GPLv3</license>
              <author>Luong Thanh Lam &lt;ltlam93@gmail.com&gt;</author>
	      <icon>/usr/local/share/ibus-vhtime/icons/vi.svg</icon>
              <layout>us</layout>
              <longname>Vhtime (US layout)</longname>
              <description>Vietnamese input method editor with US keyboard layout</description>
              <rank>1</rank>
	      <setup>/usr/local/lib/ibus-vhtime/ibus-engine-vhtime -gui</setup>
          </engine>
	  <!-- Vietnamese Icons -->
          <engine>
              <symbol>vi</symbol>
              <name>Vhtime::Candy</name>
              <language>vi</language>
              <license>GPLv3</license>
              <author>Tran Duc Binh &lt;binhtran432k@gmail.com&gt;</author>
	      <icon>/usr/local/share/ibus-vhtime/icons/vi-candy.svg</icon>
              <layout>default</layout>
              <longname>Vhtime Candy</longname>
              <description>Vietnamese input method editor with US keyboard layout with Candy Icon</description>
              <rank>1</rank>
	      <setup>/usr/local/lib/ibus-vhtime/ibus-engine-vhtime -gui</setup>
          </engine>
          <engine>
              <symbol>vi</symbol>
              <name>Vhtime::Flag</name>
              <language>vi</language>
              <license>GPLv3</license>
              <author>Tran Duc Binh &lt;binhtran432k@gmail.com&gt;</author>
	      <icon>/usr/local/share/ibus-vhtime/icons/vi-flag.svg</icon>
              <layout>default</layout>
              <longname>Vhtime Flag</longname>
              <description>Vietnamese input method editor with US keyboard layout with Flag Icon</description>
              <rank>1</rank>
	      <setup>/usr/local/lib/ibus-vhtime/ibus-engine-vhtime -gui</setup>
          </engine>
	  <!-- English (US) Icons -->
          <engine>
              <symbol>en</symbol>
              <name>VhtimeUs</name>
              <language>en</language>
              <license>GPLv3</license>
              <author>Tran Duc Binh &lt;binhtran432k@gmail.com&gt;</author>
	      <icon>/usr/local/share/ibus-vhtime/icons/us.svg</icon>
              <layout>us</layout>
              <longname>Vhtime English (US)</longname>
              <description>Vietnamese input method editor with US keyboard layout with US Normal Icon</description>
              <rank>2</rank>
	      <setup>/usr/local/lib/ibus-vhtime/ibus-engine-vhtime -gui</setup>
          </engine>
          <engine>
              <symbol>en</symbol>
              <name>VhtimeUs::Candy</name>
              <language>en</language>
              <license>GPLv3</license>
              <author>Tran Duc Binh &lt;binhtran432k@gmail.com&gt;</author>
	      <icon>/usr/local/share/ibus-vhtime/icons/us-candy.svg</icon>
              <layout>us</layout>
              <longname>Vhtime English (US) Candy</longname>
              <description>Vietnamese input method editor with US keyboard layout with US Candy Icon</description>
              <rank>2</rank>
	      <setup>/usr/local/lib/ibus-vhtime/ibus-engine-vhtime -gui</setup>
          </engine>
          <engine>
              <symbol>en</symbol>
              <name>VhtimeUs::Flag</name>
              <language>en</language>
              <license>GPLv3</license>
              <author>Tran Duc Binh &lt;binhtran432k@gmail.com&gt;</author>
	      <icon>/usr/local/share/ibus-vhtime/icons/us-flag.svg</icon>
              <layout>us</layout>
              <longname>Vhtime English (US) Flag</longname>
              <description>Vietnamese input method editor with US keyboard layout with US Flag Icon</description>
              <rank>2</rank>
	      <setup>/usr/local/lib/ibus-vhtime/ibus-engine-vhtime -gui</setup>
          </engine>
    </engines>
</component>
